<div class="vw-100 vh-100 center-div"
   style="background-image: linear-gradient(rgba(0, 0, 0, 0.5),rgba(0, 0, 0, 0.5)), url('images/bg.jpg');">
   <div class="container center-div">
      <div class="card bg-black pt-3 pb-3" id="card-signup">
         <div class="card-header text-center pb-1">
            <h1 class="h1 font-weight-bold header-letter-space" id="signup-title">CREATE AN ACCOUNT</h1>
         </div>
         <div class="card-body" id="card-body-signup">
            
            <!-- Choice Step -->
            <div id="signup-choice" class="text-center py-4">
                <p class="mb-4">How would you like to join AppointCut?</p>
                <div class="d-flex justify-content-center flex-wrap gap-3">
                    <button class="btn btn-lg btn-primary btn-custom-reg-log font-weight-bold font-small rounded-0 px-5 mb-2" onclick="showForm('owner')">SHOP OWNER</button>
                    <button class="btn btn-lg btn-primary btn-custom-reg-log font-weight-bold font-small rounded-0 px-5 mb-2" onclick="showForm('customer')">CUSTOMER</button>
                </div>
                <div class="mt-4">
                    <a href="/" class="text-white font-small">Already have an account? Sign in</a>
                </div>
            </div>

            <!-- Owner Signup Form (Hidden by default) -->
            <form class="row center-div p-0 d-none" action="/signup" id="signup-owner" method="POST" enctype="multipart/form-data">
               <input type="hidden" name="role" value="owner">
               <div class="col-sm-6">
                  <!-- nagdefine ng height para pumantay sila sa isat isa  -->
                  <div class="form-group">
                     <span>OWNER INFORMATION</span>
                     <div class="row no-gutters">
                        <div class="col-lg-6" id="xxr1">
                           <input type="text" class="form-control font-small mb-2 rounded-0" id="firstName"
                              name="firstName" placeholder="First Name" required>
                        </div>
                        <div class="col-lg-6" id="xxl1">
                           <input type="text" class="form-control font-small mb-2 rounded-0" id="lastName"
                              name="lastName" placeholder="Last Name" required>
                        </div>
                     </div>
                     <input type="email" class="form-control font-small mb-2 rounded-0" name="email" placeholder="Email"
                        required>
                     <input type="password" class="form-control font-small mb-2 rounded-0" name="password"
                        placeholder="Password" required>
                     <input type="text" class="form-control font-small mb-2 rounded-0" name="contact"
                        placeholder="Contact Number" required>
                  </div>
               </div>
               <div class="col-sm-6">
                  <!-- nagdefine ng height para pumantay sila sa isat isa  -->
                  <div class="form-group">
                     SHOP INFORMATION
                     <input type="text" class="form-control font-small mb-2 rounded-0" name="shopName"
                        placeholder="Shop Name" required>
                     <input type="email" class="form-control font-small mb-2 rounded-0" name="shopEmail"
                        placeholder="Shop Email" required>
                     <input type="text" class="form-control font-small mb-2 rounded-0" name="shopContact"
                        placeholder="Shop Contact Number" required>
                     <div class="row no-gutters">
                        <div class="col-lg-6" id="xxr2">
                           <select class="form-control font-small rounded-0" id="city" name="city"
                              onchange="setBarangay(this)" placeholder="City" required>
                              <option selected disabled hidden>City</option>
                              {{#each rowCity}}
                              <option value="{{this.CityID}}">{{this.Name}}</option>
                              {{/each}}
                           </select>
                        </div>
                        <div class="col-lg-6" id="xxl2">
                           <select class="form-control font-small rounded-0" name="brgy" id="brgySignUp" required>
                              <option selected disabled hidden>Barangay</option>
                              {{#each rowBrgy}}
                              <option value="{{this.BarangayID}}">{{this.Name}}</option>
                              {{/each}}
                           </select>
                        </div>
                     </div>
                     <div>
                        <input type="text" class="form-control font-small mt-2 mb-2 rounded-0" name="street"
                           placeholder="street" required>
                     </div>
                  </div>
               </div>
               <div>
                  <div>
                     <div class="mb-2">
                        <label for="birPermit" class="mb-0"><small>BIR PERMIT:</small></label>
                        <div class="attachment-border">
                           <input class="font-small reg-file-btn container-fluid pl-0" type="file" name="birPermit"
                              required>
                        </div>
                     </div>
                     <div class="mb-2">
                        <label for="busPermit" class="mb-0"><small>BUSINESS PERMIT:</small></label>
                        <div class="attachment-border">
                           <input class="font-small reg-file-btn container-fluid pl-0" type="file" name="busPermit"
                              required>
                        </div>
                     </div>
                     <div class="mb-2">
                        <label for="bsImage" class="mb-0"><small>BARBERSHOP LOGO/IMAGE:</small></label>
                        <div class="attachment-border">
                           <input class="font-small reg-file-btn container-fluid pl-0" type="file" name="busImage"
                              required>
                        </div>
                     </div>
                  </div>
                  <div class="text-center mt-2">
                     <button onclick="document.getElementById('signup-owner').submit()"
                        class="btn btn-lg btn-primary btn-custom-reg-log font-weight-bold font-small rounded-0 pl-5 pr-5"
                        type="submit">SIGN UP</button>
                     <p class="font-smaller m-0 mt-2">By signing up you agree to the</p>
                     <a class="font-smaller text-white" style="cursor: pointer" onclick="showTC()">Terms & Conditions</a>
                     <div class="mt-2 text-center">
                        <a href="javascript:void(0)" onclick="resetSignup()" class="text-white font-small">Back</a>
                     </div>
                  </div>
               </div>
            </form>

            <!-- Customer Signup Form (Hidden by default) -->
            <form class="center-div p-0 d-none" action="/signup" id="signup-customer" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="role" value="customer">
                <div style="width: 100%; max-width: 400px;">
                    <p class="text-center mb-3"><span>CUSTOMER INFORMATION</span></p>
                    <div class="row no-gutters">
                        <div class="col-sm-6" id="xxr3" style="padding-right: 0.125rem;">
                           <input type="text" class="form-control font-small mb-2 rounded-0" name="firstName" placeholder="First Name" required>
                        </div>
                        <div class="col-sm-6" id="xxl3" style="padding-left: 0.125rem;">
                           <input type="text" class="form-control font-small mb-2 rounded-0" name="lastName" placeholder="Last Name" required>
                        </div>
                     </div>
                     <input type="email" class="form-control font-small mb-2 rounded-0" name="email" placeholder="Email" required>
                     <input type="password" class="form-control font-small mb-2 rounded-0" name="password" placeholder="Password" required>
                     <input type="text" class="form-control font-small mb-4 rounded-0" name="contact" placeholder="Contact Number" required>
                     
                     <div class="text-center">
                        <button class="btn btn-lg btn-primary btn-custom-reg-log font-weight-bold font-small rounded-0 px-5 mb-3" type="submit">SIGN UP</button>
                        <p class="font-smaller m-0">By signing up you agree to the</p>
                        <a class="font-smaller text-white" style="cursor: pointer" onclick="showTC()">Terms & Conditions</a>
                        <div class="mt-3">
                           <a href="javascript:void(0)" onclick="resetSignup()" class="text-white font-small">Back</a>
                        </div>
                     </div>
                </div>
            </form>
         </div>
      </div>
   </div>
</div>

<script>
   function showForm(role) {
       document.getElementById('signup-choice').classList.add('d-none');
       if (role === 'owner') {
           document.getElementById('signup-owner').classList.remove('d-none');
           document.getElementById('card-body-signup').style.padding = '2rem 9rem';
       } else {
           document.getElementById('signup-customer').classList.remove('d-none');
           document.getElementById('card-body-signup').style.padding = '2rem 2rem';
       }
   }

   function resetSignup() {
       document.getElementById('signup-choice').classList.remove('d-none');
       document.getElementById('signup-owner').classList.add('d-none');
       document.getElementById('signup-customer').classList.add('d-none');
       document.getElementById('card-body-signup').style.padding = '2rem 9rem';
   }

   var newWindow;
   var w,
      h = 0;
   var width = window.innerWidth;
   var height = window.innerHeight;

   function showTC() {
      newWindow = open("tc", "tc", "width = 640, height = 480");
      w = width / 2;
      h = height / 2;
      newWindow.moveBy(w - 300, h - 200);
      newWindow.focus();
   }

   function setBarangay(el) {
      var brgyDropDown = document.getElementById("brgySignUp");
      var cityID = el.value;
      var barangay = [];
      fetch("/getInfo/barangay")
         .then((res) => res.json())
         .then((data) => {
            for (var i = 0; i < data.length; i++) {
               if (data[i].CityID == cityID) {
                  barangay.push(data[i]);
               }
            }
         })
         .then((data) => {
            var brgyOptions = "<option hidden disabled selected>Barangay</option>";
            barangay.forEach((element) => {
               brgyOptions +=
                  "<option value=" +
                  element.BarangayID +
                  "> " +
                  element.Name +
                  " </option>";
            });
            brgyDropDown.innerHTML = brgyOptions;
         });
   }
</script>
